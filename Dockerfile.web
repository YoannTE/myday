# Dockerfile.web - image de production du frontend Next.js (MyDay)
# Build : docker build -f Dockerfile.web .
# Consomme les migrations/seed generes par `npm run db:bundle-migrate`
# (script fourni par l'agent postgres-developer, cf. package.json).

# ---------------------------------------------------------------------------
# Stage 1 : dependances
# ---------------------------------------------------------------------------
FROM node:22-alpine AS deps
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

# ---------------------------------------------------------------------------
# Stage 2 : build (Next.js standalone + bundles migrate/seed)
# ---------------------------------------------------------------------------
FROM node:22-alpine AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# NEXT_PUBLIC_API_URL est inline DANS le bundle au moment du `next build`
# (variable exposee au navigateur). Elle doit donc etre fournie en build-arg
# par la plateforme (Dokploy : « Build-Time Variables »), sinon le front
# appellerait localhost:8000 en production. Defaut inoffensif pour le build local.
ARG NEXT_PUBLIC_API_URL="http://localhost:8000"
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Variables factices pour que `next build` puisse s'executer sans .env.local
# reel (les vraies valeurs sont injectees au runtime par la plateforme).
ENV NEXT_TELEMETRY_DISABLED=1
ENV DATABASE_URL="postgres://build:build@localhost:5432/build"
ENV BETTER_AUTH_SECRET="build-time-secret-placeholder"
ENV BETTER_AUTH_URL="http://localhost:3000"
ENV S3_ENDPOINT="http://localhost:9000"
ENV S3_REGION="us-east-1"
ENV S3_BUCKET="app-files"
ENV S3_ACCESS_KEY_ID="build"
ENV S3_SECRET_ACCESS_KEY="build"
ENV S3_FORCE_PATH_STYLE="true"
ENV S3_PUBLIC_URL="http://localhost:9000/app-files"

RUN npm run db:bundle-migrate
RUN npm run build

# ---------------------------------------------------------------------------
# Stage 3 : image d'execution (runtime minimal)
# ---------------------------------------------------------------------------
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

RUN addgroup --system --gid 1001 nodejs \
  && adduser --system --uid 1001 nextjs

# Sortie standalone Next.js (server.js + node_modules traces + package.json)
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

# Bundles migration/seed produits par db:bundle-migrate
COPY --from=builder --chown=nextjs:nodejs /app/dist ./dist

# Migrations SQL Drizzle : lues sur disque au runtime par migrate.js
# (drizzle-orm ne bundle pas les .sql ni meta/_journal.json)
COPY --from=builder --chown=nextjs:nodejs /app/drizzle ./drizzle

COPY --chown=nextjs:nodejs entrypoint.web.sh ./entrypoint.web.sh
RUN chmod +x ./entrypoint.web.sh

USER nextjs
EXPOSE 3000

ENTRYPOINT ["./entrypoint.web.sh"]
